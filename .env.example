DOME_ROOT=/Users/gadikedoshim/DOME-HUB
DOME_ENV=dev  # dev | prod

# Provider strategy — controls which LLM agents use
# local  = Ollama/MLX only, fully air-gapped
# claude = Anthropic API for all agents
# mixed  = per-agent optimal (default)
DOME_PROVIDER=mixed
DOME_LOCAL_MODEL=llama3.1:8b

# AI/ML model cache — all weights stay inside DOME-HUB
SENTENCE_TRANSFORMERS_HOME=/Users/gadikedoshim/DOME-HUB/models
HF_HOME=/Users/gadikedoshim/DOME-HUB/models/hf
TRANSFORMERS_CACHE=/Users/gadikedoshim/DOME-HUB/models/hf
TORCH_HOME=/Users/gadikedoshim/DOME-HUB/models/torch
MLX_MODEL_PATH=/Users/gadikedoshim/DOME-HUB/models/mlx

# Cloud API keys — secondary, use only when local is insufficient
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
CLAUDE_AGENT_WORKDIR=/Users/gadikedoshim/DOME-HUB
GITHUB_PERSONAL_ACCESS_TOKEN=
# OPENAI_API_KEY=  # avoid — not sovereign
