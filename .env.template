DOME_ROOT=${HOME}/DSH
DOME_ENV=dev  # dev | prod

# Provider strategy
# local  = Ollama/MLX only, fully air-gapped
# claude = Anthropic API for all agents
# mixed  = per-agent optimal (default)
DOME_PROVIDER=mixed
DOME_LOCAL_MODEL=qwen3.5:9b

# AI/ML model cache — all weights stay inside DOME-HUB
SENTENCE_TRANSFORMERS_HOME=${HOME}/DSH/models
HF_HOME=${HOME}/DSH/models/hf
TRANSFORMERS_CACHE=${HOME}/DSH/models/hf
TORCH_HOME=${HOME}/DSH/models/torch
MLX_MODEL_PATH=${HOME}/DSH/models/mlx

# Cloud API keys — resolved from macOS Keychain at render time
ANTHROPIC_API_KEY={{keychain:dome/ANTHROPIC_API_KEY}}
ANTHROPIC_MODEL=claude-opus-4-6
CLAUDE_AGENT_WORKDIR=${HOME}/DSH
GITHUB_PERSONAL_ACCESS_TOKEN={{keychain:dome/GITHUB_PERSONAL_ACCESS_TOKEN}}
# OPENAI_API_KEY=  # avoid — not sovereign

# Trinity Consortium mesh
TRINITY_API_BASE=http://127.0.0.1:3333
TRINITY_CONSORTIUM_BASE=http://127.0.0.1:5055
HUB_API_SECRET={{keychain:dome/HUB_API_SECRET}}
TRINITY_JWT={{keychain:dome/TRINITY_JWT}}

# Misc
KMP_DUPLICATE_LIB_OK=TRUE
ELEVENLABS_API_KEY={{keychain:dome/ELEVENLABS_API_KEY}}
