logs/*.md
logs/*.log
logs/reports/

# Full local databases (schema lives in code, data stays per-node)
db/

# Google Drive desktop sync mount — not source of truth
google drive/
Google Drive/

# Ollama pulled model weights — downloaded per-node
models/ollama/

# Python build artifacts
build/
*.egg-info/
.pytest_cache/

# IDE / OS cruft
.idea/
*.swp
.DS_Store
.fractalmap/
.kiro/

# ── Local-only content (never push) ──

# Akashic books library — PDFs, extracted text, images (653MB+, copyrighted)
