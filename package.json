{
  "name": "dome-hub",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,json,md}'",
    "typecheck": "tsc --noEmit",
    "ingest": "python3 scripts/ingest.py",
    "serve": "python3 -m uvicorn agents.api.server:app --reload --port 8000",
    "worker": "python3 -m agents.workers.queue",
    "audit": "bash scripts/audit.sh",
    "sync": "git pull && python3 scripts/ingest.py && git add -A && git commit -m \"sync: auto\" && git push"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "kiro-cli": "^0.0.1",
    "latest": "^0.2.0"
  }
}