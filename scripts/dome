#!/usr/bin/env python3
"""dome — DSH agent CLI"""
import sys, json, requests

API = "http://127.0.0.1:8001"

def usage():
    print("""dome — DSH Agent CLI

Usage:
  dome ask <agent> "<prompt>"     Run an agent
  dome list                       List available agents
  dome health                     Check stack health
  dome rag "<query>"              Query knowledge base

Agents: coder, researcher, analyst, planner, local, security,
        devops, creative, orchestrator, akashic, healer, monitor

Examples:
  dome ask coder "write a Redis cache wrapper in Python"
  dome ask researcher "what is the E8 lattice?"
  dome ask planner "break down building a FastAPI service"
  dome rag "what is the Mycelium mesh?"
""")

def ask(agent, prompt):
    try:
        r = requests.post(f"{API}/agents/{agent}/run",
                          json={"prompt": prompt}, timeout=120)
        r.raise_for_status()
        print(r.json().get("response", r.text))
    except requests.exceptions.ConnectionError:
        print("Error: DSH server not running. Start it with: pnpm serve")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

def list_agents():
    r = requests.get(f"{API}/agents", timeout=10)
    for a in r.json().get("agents", []):
        print(f"  {a}")

def health():
    r = requests.get(f"{API}/health", timeout=10)
    d = r.json()
    print(f"status: {d['status']}")
    for k, v in d.get("stack", {}).items():
        icon = "✅" if v == "ok" else "❌"
        print(f"  {icon} {k}: {v}")

def rag(query):
    r = requests.post(f"{API}/rag/query",
                      json={"query": query, "n_results": 5}, timeout=30)
    results = r.json().get("results", [])
    for i, res in enumerate(results, 1):
        print(f"\n[{i}] {res.get('document', '')[:300]}")

def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        usage(); return

    cmd = args[0]
    if cmd == "ask":
        if len(args) < 3:
            print("Usage: dome ask <agent> \"<prompt>\""); sys.exit(1)
        ask(args[1], " ".join(args[2:]))
    elif cmd == "list":
        list_agents()
    elif cmd == "health":
        health()
    elif cmd == "rag":
        if len(args) < 2:
            print("Usage: dome rag \"<query>\""); sys.exit(1)
        rag(" ".join(args[1:]))
    else:
        print(f"Unknown command: {cmd}"); usage(); sys.exit(1)

if __name__ == "__main__":
    main()
